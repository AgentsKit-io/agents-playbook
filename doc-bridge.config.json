{
  "schemaVersion": 1,
  "project": {
    "name": "agents-playbook"
  },
  "corpus": {
    "agent": {
      "root": "content/docs",
      "index": "content/docs/index.mdx",
      "include": [
        "**/*.{md,mdx}"
      ],
      "exclude": [
        "**/meta.json",
        "**/node_modules/**"
      ],
      "okf": {
        "requireType": true
      }
    },
    "human": {
      "plugin": "fumadocs",
      "options": {
        "contentDir": "content/docs",
        "urlPrefix": "/docs",
        "metaFile": "meta.json"
      }
    }
  },
  "routing": {
    "options": {
      "intents": [
        {
          "id": "find-pattern",
          "title": "Find a playbook pattern by pillar or name",
          "paths": [
            "content/docs/pillars",
            "content/docs/matrix.md"
          ]
        },
        {
          "id": "onboard-agent",
          "title": "Onboard a coding agent to this playbook",
          "paths": [
            "content/docs/onboard-your-agent.md",
            "content/docs/getting-started.mdx"
          ]
        }
      ],
      "changes": [
        {
          "id": "new-pattern",
          "title": "Add or revise a pattern under pillars/",
          "startHere": "content/docs/pillars"
        }
      ],
