{
  "name": "agents-playbook",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbo",
    "prebuild": "node scripts/gen-stats-snapshot.mjs && node scripts/build-discovery.mjs && node scripts/build-bundle.mjs",
    "gen:stats": "node scripts/gen-stats-snapshot.mjs",
    "gen:okf-type": "node scripts/add-okf-type.mjs",
    "check:okf-type": "node scripts/add-okf-type.mjs --check",
    "build": "next build",
    "start": "next start",
    "postinstall": "fumadocs-mdx",
    "build:bundle": "node scripts/build-bundle.mjs",
    "build:discovery": "node scripts/build-discovery.mjs",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:readme-standard": "vitest run scripts/readme-standard.test.mjs",
    "test:onboarding": "vitest run scripts/onboarding-proof.test.mjs",
    "test:playbook-package": "node --test packages/playbook/test/cli.test.mjs",
    "test:e2e": "playwright test",
    "sync:playbook-package": "node scripts/sync-playbook-package.mjs",
    "check:playbook-package": "node scripts/sync-playbook-package.mjs --check",
    "check:readme-standard": "node scripts/check-readme-standard.mjs",
    "readme:standard:refresh": "node scripts/refresh-readme-standard.mjs",
    "docs:bridge:config": "node scripts/generate-doc-bridge-config.mjs",
    "check:doc-bridge-config": "node scripts/generate-doc-bridge-config.mjs --check",
    "docs:bridge:index": "node scripts/generate-doc-bridge-config.mjs && ak-docs index",
    "docs:bridge:query": "ak-docs query",
    "docs:bridge:gate": "ak-docs gate run",
    "docs:bridge:doctor": "ak-docs doctor",
    "docs:bridge:conformance": "ak-docs conformance run documentation-standard-v1 --text",
    "check:doc-bridge-score": "node scripts/check-doc-bridge-score.mjs",
    "check:all": "pnpm check:okf-type && pnpm check:playbook-package && pnpm check:doc-bridge-config && pnpm docs:bridge:index && pnpm docs:bridge:gate && pnpm check:doc-bridge-score && pnpm check:readme-standard && pnpm test && pnpm test:playbook-package && pnpm lint && pnpm build"
  },
  "dependencies": {
    "@agentskit/chat": "0.4.0",
    "@agentskit/core": "^1.12.3",
    "@agentskit/react": "^0.7.4",
    "fumadocs-core": "15.6.5",
    "fumadocs-mdx": "11.6.4",
    "fumadocs-ui": "15.6.5",
    "lucide-react": "^0.460.0",
    "next": "^15.1.0",
    "posthog-js": "^1.386.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@agentskit/doc-bridge": "1.1.1",
    "@playwright/test": "^1.55.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/mdx": "^2.0.13",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": "22.x"
  }
}
