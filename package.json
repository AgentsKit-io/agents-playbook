{
  "name": "agents-playbook",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbo",
    "prebuild": "node scripts/gen-stats-snapshot.mjs",
    "gen:stats": "node scripts/gen-stats-snapshot.mjs",
    "gen:okf-type": "node scripts/add-okf-type.mjs",
    "check:okf-type": "node scripts/add-okf-type.mjs --check",
    "build": "node scripts/build-bundle.mjs && next build",
    "start": "next start",
    "postinstall": "fumadocs-mdx",
    "build:bundle": "node scripts/build-bundle.mjs",
    "lint": "tsc --noEmit",
    "docs:bridge:index": "ak-docs index",
    "docs:bridge:query": "ak-docs query",
    "docs:bridge:gate": "ak-docs gate run"
  },
  "dependencies": {
    "@agentskit/chat": "0.2.0",
    "@agentskit/chat-protocol": "0.2.0",
    "@agentskit/chat-react": "0.2.0",
    "@agentskit/core": "^1.12.3",
    "@agentskit/react": "^0.7.4",
    "fumadocs-core": "15.6.5",
    "fumadocs-mdx": "11.6.4",
    "fumadocs-ui": "15.6.5",
    "lucide-react": "^0.460.0",
    "next": "^15.1.0",
    "posthog-js": "^1.386.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@agentskit/doc-bridge": "1.0.2",
    "@types/mdx": "^2.0.13",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": "22.x"
  }
}
