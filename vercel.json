{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "git": {
    "deploymentEnabled": {
      "**": false,
      "main": true,
      "master": true,
      "staging": true,
      "qa": true,
      "dev": true,
      "develop": true
    }
  },

  "buildCommand": "npx -y pnpm@9.15.4 build",
  "installCommand": "npx -y pnpm@9.15.4 install --no-frozen-lockfile",
  "framework": "nextjs",
  "headers": [
    {
      "source": "/llms(.*)",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=3600" }
      ]
    }
  ]
}
